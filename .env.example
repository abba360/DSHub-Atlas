NODE_ENV=development
PORT=4000
APP_NAME=DSHub Auth Service
CORS_ORIGIN=http://localhost:3000,http://localhost:4000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/dshub_auth

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=dshub_refresh_token
REFRESH_COOKIE_MAX_AGE_MS=604800000
BCRYPT_SALT_ROUNDS=12

ADMIN_BOOTSTRAP_NAME=DSHub Super Admin
ADMIN_BOOTSTRAP_EMAIL=admin@dshub.com
ADMIN_BOOTSTRAP_PASSWORD=SecurePass123
